{
  "rewrites": [
    {
      "source": "/books",
      "destination": "/api/books"
    },
    {
      "source": "/books/:id",
      "destination": "/api/books/:id"
    },
    {
      "source": "/drafts",
      "destination": "/api/drafts"
    },
    {
      "source": "/drafts/:id",
      "destination": "/api/drafts/:id"
    },
    {
      "source": "/suggestions",
      "destination": "/api/suggestions"
    },
    {
      "source": "/suggestions/:id",
      "destination": "/api/suggestions/:id"
    },
    {
      "source": "/auth/session",
      "destination": "/api/auth/session"
    },
    {
      "source": "/auth/login",
      "destination": "/api/auth/login"
    },
    {
      "source": "/auth/logout",
      "destination": "/api/auth/logout"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    }
  ]
}
