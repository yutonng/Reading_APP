ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-private-password
ADMIN_SESSION_SECRET=replace-with-a-random-secret
ADMIN_API_TOKEN=replace-with-a-long-random-machine-token
HOST=0.0.0.0
PORT=8787

# Required on Vercel if you want admin edits to persist after deploys.
BLOB_READ_WRITE_TOKEN=vercel-blob-read-write-token
BOOKS_BLOB_PATH=data/books.json

# Used by Android/iOS builds to reach the deployed API.
EXPO_PUBLIC_API_URL=https://reading-app-sigma.vercel.app

# Optional: enables automatic cover generation when saving new drafts/books.
OPENAI_API_KEY=sk-your-openai-api-key
COVER_IMAGE_MODEL=gpt-image-2
COVER_IMAGE_QUALITY=medium

# Optional: set this to a persistent disk path in production.
# DATA_PATH=/data/books.json
